# Copy this file to .env.local and fill in your Supabase project details.
# Create a project at https://supabase.com, then find these values in:
#   Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Displayed in the UI and on certificates
NEXT_PUBLIC_RACE_NAME=City Marathon 2026

# ── Notifications (optional) ────────────────────────────────────────────────
# Email via Resend (https://resend.com). Server-side only — never exposed.
RESEND_API_KEY=re_your_resend_key
# Verified-domain sender. If unset, falls back to onboarding@resend.dev, which
# only delivers to your own Resend account email (test mode).
RESEND_FROM=noreply@your-verified-domain.com
# WhatsApp group invite shown on /status once a participant is confirmed.
NEXT_PUBLIC_WHATSAPP_INVITE_URL=https://chat.whatsapp.com/your-invite-code
