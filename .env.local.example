# Copy this file to .env.local and fill in your Supabase project details.
# Create a project at https://supabase.com, then find these values in:
#   Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Displayed in the UI and on certificates
NEXT_PUBLIC_RACE_NAME=City Marathon 2026
